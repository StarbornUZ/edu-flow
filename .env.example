# EduFlow — muhit o'zgaruvchilari namunasi
# Bu faylni .env ga nusxalang va qiymatlarni to'ldiring:
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)

# =========================================================
# DATABASE — PostgreSQL
# =========================================================
# Docker (local): port 15432 (standart 5432 band bo'lishi mumkin)
DATABASE_URL=postgresql+asyncpg://eduflow:eduflow_dev_pass@localhost:15432/eduflow

# Supabase: https://supabase.com → Settings → Database → Connection string
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# Railway: https://railway.app → PostgreSQL → Connect
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST:PORT/railway

# Docker Compose ichidagi servislar uchun (hostname = container nomi):
# DATABASE_URL=postgresql+asyncpg://eduflow:eduflow_dev_pass@postgres:5432/eduflow

# =========================================================
# DATABASE — konteyner sozlamalari (docker-compose.yml uchun)
# =========================================================
POSTGRES_DB=eduflow
POSTGRES_USER=eduflow
POSTGRES_PASSWORD=eduflow_dev_pass

# =========================================================
# REDIS
# =========================================================
# Docker (local): port 16379
REDIS_URL=redis://:eduflow_redis_pass@localhost:16379

# Railway: Add Redis service → Connect
# REDIS_URL=redis://:PASSWORD@HOST:PORT

# Docker Compose ichidagi servislar uchun:
# REDIS_URL=redis://:eduflow_redis_pass@redis:6379

# Redis parol (docker-compose uchun)
REDIS_PASSWORD=eduflow_redis_pass

# =========================================================
# JWT — Token sozlamalari
# =========================================================
# Ishlab chiqarish uchun yangi kalit generatsiya qilish:
#   python -c "import secrets; print(secrets.token_hex(32))"
#   uv run python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=super-secret-key-change-this-in-production-use-32-hex-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# =========================================================
# AI — OpenAI (asosiy model: GPT-4o)
# =========================================================
# API key: https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# =========================================================
# AI — Anthropic Claude (zaxira / fallback)
# =========================================================
# OpenAI bilan xatolik bo'lganda yoki OPENAI_API_KEY bo'lmaganda ishlatiladi
# API key: https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-api03-...

# =========================================================
# CORS — Frontend manzillari
# =========================================================
# Vergul bilan ajratilgan URL lar ro'yxati (bo'shliqsiz)
# Development:
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Local tarmoq orqali frontend ulanishi uchun (make network → IP ni aniqlang):
# ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.111:3000

# Production:
# ALLOWED_ORIGINS=https://eduflow.vercel.app

# =========================================================
# FRONTEND — URL sozlamalari
# =========================================================
FRONTEND_URL=http://localhost:3000

# =========================================================
# pgAdmin — (make up-tools keyin http://localhost:15050)
# =========================================================
PGADMIN_EMAIL=admin@eduflow.dev
PGADMIN_PASSWORD=admin

# =========================================================
# Celery — Task Queue
# =========================================================
# Celery broker (odatda Redis bilan bir xil)
CELERY_BROKER_URL=redis://:eduflow_redis_pass@localhost:16379/0
CELERY_RESULT_BACKEND=redis://:eduflow_redis_pass@localhost:16379/1

# =========================================================
# PORTLAR (ma'lumot uchun, docker-compose.yml bilan bir xil)
# =========================================================
# PostgreSQL : localhost:15432  (standart 5432 ehtimol band)
# Redis      : localhost:16379  (standart 6379)
# pgAdmin    : localhost:15050
# Mailpit    : localhost:15025  (SMTP: localhost:11025)
# Flower     : localhost:15555
# Backend    : localhost:18000  (Docker container)
# Backend    : localhost:8000   (make dev — host da)
